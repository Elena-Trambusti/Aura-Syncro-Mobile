# Add project specific R8 rules here.
# AGP will combine all keep rule files in src/main/keepRules to pass to R8

-keepclassmembers class com.aurasyncromobile.app.WebAppInterface {
    @android.webkit.JavascriptInterface <methods>;
}

-keep class com.aurasyncromobile.app.WebAppInterface { *; }

-keepattributes JavascriptInterface
